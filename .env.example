# Copy to `.env` and fill in. `.env` is gitignored.
# Scripts read these via os.environ.get() with defaults; launchd users source
# this file via the run_*.sh wrappers in this repo (or set EnvironmentVariables
# directly in the plist).

# --- Apple credentials (used by login.py for the one-time 2FA dance) ---
APPLE_EMAIL=you@example.com
APPLE_PASSWORD=change-me

# --- Local Anisette server (Docker: dadoum/anisette-v3-server on :6969) ---
ANISETTE_URL=http://localhost:6969

# --- Google Maps JS API key (injected into map.html via Jinja by server.py) ---
# Get one from https://console.cloud.google.com/, enable "Maps JavaScript API",
# and restrict it by HTTP referrer to your localhost / Tailscale hostnames.
GOOGLE_MAPS_API_KEY=
