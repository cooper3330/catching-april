# Copy to `.env` and fill in. `.env` is gitignored.
# `poller.py` reads these via os.environ.get() with defaults; systemd users
# can set the same names via `Environment=` lines instead.

# Apple ID that FindMy.app uses to see the AirTag.
APPLE_EMAIL=you@example.com
APPLE_PASSWORD=change-me

# Local Anisette server (Docker: dadoum/anisette-v3-server on :6969).
ANISETTE_URL=http://localhost:6969
